{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Unlocking in Lockman is a mechanism for properly releasing acquired locks. It ensures resource release and maintains system consistency in all situations, including after processing completion, error occurrence, or cancellation.","type":"text"}]},{"anchor":"Specifications","text":"Specifications","type":"heading","level":2},{"anchor":"Automatic-Release","text":"Automatic Release","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"When using "},{"type":"reference","isActive":true,"overridingTitleInlineContent":[{"text":"Reducer.lock","type":"text"}],"identifier":"doc:\/\/Lockman\/documentation\/Lockman\/Lock","overridingTitle":"Reducer.lock"},{"type":"text","text":", "},{"type":"reference","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"Effect.lock"}],"identifier":"doc:\/\/Lockman\/documentation\/Lockman\/Lock","overridingTitle":"Effect.lock"},{"type":"text","text":", or the auto-release version of "},{"type":"reference","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"withLock"}],"identifier":"doc:\/\/Lockman\/documentation\/Lockman\/Lock","overridingTitle":"withLock"},{"type":"text","text":", locks are automatically released at the following timings:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"On normal completion"}],"type":"strong"},{"text":": When processing completes normally","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"On exception"}]},{"text":": When an error occurs","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"On cancellation"}]},{"type":"text","text":": When processing is cancelled"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"On early return"}],"type":"strong"},{"text":": When processing ends prematurely","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Automatic release is implemented using defer blocks, ensuring that locks are reliably released regardless of the termination pattern."}]},{"anchor":"Manual-Release","text":"Manual Release","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Manual release is only available in the manual release version of "},{"type":"reference","identifier":"doc:\/\/Lockman\/documentation\/Lockman\/Lock","isActive":true,"overridingTitleInlineContent":[{"text":"withLock","type":"text"}],"overridingTitle":"withLock"},{"type":"text","text":". When using "},{"type":"reference","identifier":"doc:\/\/Lockman\/documentation\/Lockman\/Lock","isActive":true,"overridingTitleInlineContent":[{"text":"Reducer.lock","type":"text"}],"overridingTitle":"Reducer.lock"},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/Lockman\/documentation\/Lockman\/Lock","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"Effect.lock"}],"overridingTitle":"Effect.lock"},{"type":"text","text":", locks are always automatically managed."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Important constraints:"}]}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"You must call unlock() in all code paths"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Forgetting to call unlock() causes permanent lock acquisition state"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Proper release is necessary even in conditional branches and error handling","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Unlock object characteristics:"}],"type":"strong"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Conforms to the Sendable protocol, allowing it to be passed when calling other actions","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Designed for use across multiple screens and actions"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Enables shared lock state and coordinated release between actions","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","text":"Release Options","anchor":"Release-Options","level":3},{"type":"paragraph","inlineContent":[{"text":"Unlock execution timing can be controlled with LockmanUnlockOption:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"immediate","type":"text"}],"type":"strong"},{"text":": Release immediately upon processing completion","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"mainRunLoop","type":"text"}]},{"text":": Release in the next main run loop cycle","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"transition","type":"text"}],"type":"strong"},{"text":": Release after platform-specific screen transition animation completion","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS: 0.35 seconds (push\/pop animation)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS: 0.25 seconds (window and view animation)"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"tvOS: 0.4 seconds (focus-driven transition)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"watchOS: 0.3 seconds (page-based navigation)","type":"text"}]}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"delayed(TimeInterval)"}]},{"type":"text","text":": Release after specified time"}]}]}],"type":"unorderedList"},{"type":"heading","text":"Methods","anchor":"Methods","level":2},{"type":"heading","text":"Auto-release with Reducer.lock (Recommended)","anchor":"Auto-release-with-Reducerlock-Recommended","level":3},{"code":["var body: some ReducerOf<Self> {","    Reduce { state, action in","        switch action {","        case .startWork:","            return .run { send in","                try await someAsyncWork()","                await send(.completed)","                \/\/ Lock is automatically released here","            }","            .catch { error, send in","                await send(.failed(error))","                \/\/ Automatically released after error handling","            }","        }","    }","    .lock(","        boundaryId: CancelID.feature,","        unlockOption: .immediate  \/\/ Configure unlock timing","    )","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Auto-release with Effect.lock","anchor":"Auto-release-with-Effectlock","level":3},{"code":["return .run { send in","    try await someAsyncWork()","    await send(.completed)","    \/\/ Lock is automatically released here","}",".catch { error, send in","    await send(.failed(error))","    \/\/ Automatically released after error handling","}",".lock(","    action: action,","    boundaryId: CancelID.feature,","    unlockOption: .transition  \/\/ Configure unlock timing",")"],"type":"codeListing","syntax":"swift"},{"text":"Auto-release with withLock","anchor":"Auto-release-with-withLock","level":3,"type":"heading"},{"code":[".withLock(","  operation: { send in","    \/\/ Execute processing","    try await someAsyncWork()","    await send(.completed)","    \/\/ Lock is automatically released here","  },","  catch handler: { error, send in","    \/\/ Automatically released after error handling","    await send(.failed(error))","  },","  action: action,","  boundaryId: CancelID.feature",")"],"type":"codeListing","syntax":"swift"},{"text":"Manual Release Usage Example","anchor":"Manual-Release-Usage-Example","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Basic usage example:"}],"type":"paragraph"},{"code":[".withLock(","  operation: { send, unlock in","    try await firstOperation()","    ","    if shouldEarlyReturn {","      unlock() \/\/ Early release","      return","    }","    ","    try await secondOperation()","    unlock() \/\/ Required: Final release","  },","  catch handler: { error, send, unlock in","    \/\/ Error handling","    unlock() \/\/ Release on error too","    send(.failed(error))","  },","  action: action,","  boundaryId: cancelID",")"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Example of release in another screen’s delegate:"}],"type":"paragraph"},{"code":[".withLock(","  operation: { send, unlock in","    \/\/ Pass unlock object to another screen and transition","    send(.delegate(unlock: unlock))","  },","  action: action,","  boundaryId: cancelID",")","","\/\/ Receive and release on the delegate side","case .modal(.delegate(let unlock)):","  return .run { send in","    \/\/ Release after modal processing completion","    unlock()","  }"],"type":"codeListing","syntax":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Lockman\/documentation\/Lockman\/Unlock"},"sections":[],"hierarchy":{"paths":[["doc:\/\/Lockman\/documentation\/Lockman"]]},"abstract":[{"type":"text","text":"Understanding the unlocking mechanism in Lockman."}],"seeAlsoSections":[{"identifiers":["doc:\/\/Lockman\/documentation\/Lockman\/GettingStarted","doc:\/\/Lockman\/documentation\/Lockman\/BoundaryOverview","doc:\/\/Lockman\/documentation\/Lockman\/Lock","doc:\/\/Lockman\/documentation\/Lockman\/ChoosingStrategy","doc:\/\/Lockman\/documentation\/Lockman\/Configuration","doc:\/\/Lockman\/documentation\/Lockman\/ErrorHandling","doc:\/\/Lockman\/documentation\/Lockman