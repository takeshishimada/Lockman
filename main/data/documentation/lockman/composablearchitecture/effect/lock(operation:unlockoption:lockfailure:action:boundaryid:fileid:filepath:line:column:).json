]}],"name":"lockFailure"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"LockmanAction providing lock information and strategy type"}]}],"name":"action"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unique identifier for effect cancellation and lock boundary"}]}],"name":"boundaryId"},{"content":[{"inlineContent":[{"type":"text","text":"Source file ID for debugging (auto-populated)"}],"type":"paragraph"}],"name":"fileID"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Source file path for debugging (auto-populated)"}]}],"name":"filePath"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Source line number for debugging (auto-populated)","type":"text"}]}],"name":"line"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Source column number for debugging (auto-populated)","type":"text"}]}],"name":"column"}]},{"kind":"content","content":[{"text":"Return Value","anchor":"return-value","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Effect with automatic lock management, or "},{"type":"codeVoice","code":".none"},{"type":"text","text":" if lock acquisition fails"}],"type":"paragraph"}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"This method provides a factory-style API for applying lock management to a single effect."},{"type":"text","text":" "},{"type":"text","text":"It serves as a conceptually correct alternative to method chaining, maintaining proper"},{"type":"text","text":" "},{"type":"text","text":"dependency relationships where the Action defines the locking behavior rather than the Effect."}],"type":"paragraph"},{"text":"Design Philosophy","anchor":"Design-Philosophy","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"This method follows the principle that Actions should control Effects, not the reverse."},{"type":"text","text":" "},{"type":"text","text":"By using a static factory method, we maintain clear separation of concerns:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Action"}],"type":"strong"},{"type":"text","text":": Defines what should be locked and how"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Effect","type":"text"}],"type":"strong"},{"type":"text","text":": Defines what work should be performed"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Factory"}],"type":"strong"},{"text":": Combines them with proper lock management","type":"text"}]}]}]},{"text":"Lock Lifecycle & UniqueId Consistency","anchor":"Lock-Lifecycle--UniqueId-Consistency","type":"heading","level":2},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"LockmanInfo Capture"}],"type":"strong"},{"text":": Action’s lockmanInfo is captured once at the beginning to ensure consistent uniqueId","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Lock Acquisition"}]},{"type":"text","text":": Lock is acquired before the operation starts using the captured lockmanInfo"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Effect Execution"}],"type":"strong"},{"type":"text","text":": Lock is held during execution of the single operation"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Guaranteed Unlock","type":"text"}]},{"type":"text","text":": Lock is automatically released after operation completes using the same lockmanInfo instance"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Error Handling"}]},{"type":"text","text":": If operation fails, lock is still properly released with matching uniqueId"}]}]}]},{"text":"Automatic Cancellation Management","anchor":"Automatic-Cancellation-Management","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"This method automatically applies "},{"code":".cancellable(id: boundaryId)","type":"codeVoice"},{"type":"text","text":" to the operation"},{"type":"text","text":" "},{"type":"text","text":"while ensuring the unlock effect is never cancelled. This follows the"},{"type":"text","text":" "},{"type":"text","text":"“Guaranteed Resource Cleanup” principle:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Operation is cancellable","type":"text"}]},{"type":"text","text":": The operation can be cancelled via boundaryId"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Resource cleanup is guaranteed","type":"text"}]},{"type":"text","text":": Unlock always executes to prevent resource leaks"}]}]}]},{"text":"Example Usage","anchor":"Example-Usage","type":"heading","level":2},{"syntax":"swift","code":["\/\/ Single async operation with lock","return Effect.lock(","  operation: .run { send in","    let result = await fetchUserData()","    await send(.userDataLoaded(result))","  },","  action: action,","  boundaryId: Feature.self",")","","\/\/ Send action with lock","return Effect.lock(","  operation: .send(.startLoading),","  action: action,","  boundaryId: Feature.self",")"],"type":"codeListing"}]}],"references":{"doc://Lockman/documentation/Lockman/ComposableArchitecture":{"url":"\/documentation\/lockman\/composablearchitecture","identifier":"doc:\/\/Lockman\/documentation\/Lockman\/ComposableArchitecture","kind":"symbol","title":"ComposableArchitecture","type":"topic","role":"collection","abstract":[]},"doc://Lockman/documentation/Lockman/LockmanAction":{"abstract":[{"text":"An action that participates in Lockman’s locking mechanism.