{"kind":"article","primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"LockmanManager provides configuration functionality to set Lockman’s behavior throughout the application. These settings allow you to customize default lock release timing and error handling behavior.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once configured, settings apply application-wide and can be overridden in individual "},{"type":"reference","isActive":true,"overridingTitle":"withLock","identifier":"doc:\/\/Lockman\/documentation\/Lockman\/Lock","overridingTitleInlineContent":[{"type":"codeVoice","code":"withLock"}]},{"type":"text","text":" calls."}]},{"type":"heading","level":2,"anchor":"Configuration-Options","text":"Configuration Options"},{"type":"heading","level":3,"anchor":"defaultUnlockOption","text":"defaultUnlockOption"},{"type":"paragraph","inlineContent":[{"text":"Sets the default timing for lock release.","type":"text"}]},{"type":"codeListing","code":["\/\/ Configure during application initialization","LockmanManager.config.defaultUnlockOption = .immediate"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Available values","type":"text"}],"type":"strong"},{"text":":","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":".immediate"}]},{"type":"text","text":": Release immediately upon completion (default)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":".mainRunLoop"}]},{"text":": Release on the next main loop cycle","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"code":".transition","type":"codeVoice"}],"type":"strong"},{"type":"text","text":": Release after platform-specific screen transition animation"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"codeVoice","code":".delayed(TimeInterval)"}],"type":"strong"},{"text":": Release after the specified time interval","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Use cases","type":"text"}]},{"type":"text","text":":"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unified release timing considering UI transitions"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Consistent behavior settings across the application","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Adjustments for performance optimization","type":"text"}]}]}]},{"type":"heading","level":3,"anchor":"handleCancellationErrors","text":"handleCancellationErrors"},{"type":"paragraph","inlineContent":[{"text":"Sets how to handle cancellation errors.","type":"text"}]},{"type":"codeListing","code":["\/\/ Ignore cancellation errors (default)","LockmanManager.config.handleCancellationErrors = false","","\/\/ Pass cancellation errors to error handler","LockmanManager.config.handleCancellationErrors = true"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Values"}],"type":"strong"},{"text":":","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"false","type":"codeVoice"}]},{"type":"text","text":": Ignore cancellation errors and don’t pass to error handler (default)"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"code":"true","type":"codeVoice"}],"type":"strong"},{"text":": Pass cancellation errors to error handler","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Use cases"}],"type":"strong"},{"text":":","type":"text"}]},{"type":"unorderedList","items":