mentation/Lockman/Unlock":{"title":"Unlock","type":"topic","kind":"article","abstract":[{"type":"text","text":"Understanding the unlocking mechanism in Lockman."}],"url":"\/documentation\/lockman\/unlock","identifier":"doc:\/\/Lockman\/documentation\/Lockman\/Unlock","role":"article"}}}