{"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LockmanCancellationError","kind":"identifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"inlineContent":[{"text":"This structure provides a consistent way to handle cancellation scenarios across","type":"text"},{"text":" ","type":"text"},{"text":"different strategies, while preserving access to the original action that was","type":"text"},{"text":" ","type":"text"},{"text":"cancelled and the specific strategy error that caused the cancellation.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Purpose","level":2,"anchor":"Purpose"},{"inlineContent":[{"type":"text","text":"When a lock acquisition fails or an existing action needs to be cancelled,"},{"type":"text","text":" "},{"type":"text","text":"this error provides:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The actual action instance that was cancelled (not just its ID)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The boundary where the cancellation occurred"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The underlying strategy-specific error with detailed reason","type":"text"}]}]}],"type":"unorderedList"},{"type":"heading","text":"Usage in Error Handlers","level":2,"anchor":"Usage-in-Error-Handlers"},{"type":"codeListing","code":["lockFailure: { error, send in","    if let cancellation = error as? LockmanCancellationError {","        \/\/ Access the actual action that was cancelled","        let action = cancellation.action","","        \/\/ Check the underlying strategy error","        switch cancellation.reason {","        case let singleError as LockmanSingleExecutionError:","            \/\/ Handle single execution conflicts","        case let priorityError as LockmanPriorityBasedError:","            \/\/ Handle priority conflicts","        default:","            \/\/ Handle other errors","        }","    }","}"],"syntax":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/Lockman\/documentation\/Lockman"]]},"metadata":{"externalID":"s:7Lockman0A17CancellationErrorV","modules":[{"name":"Lockman"}],"navigatorTitle":[{"text":"LockmanCancellationError","kind":"identifier"}],"title":"LockmanCancellationError","roleHeading":"Structure","symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LockmanCancellationError","kind":"identifier"}],"role":"symbol"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/lockman\/lockmancancellationerror"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"A unified error structure that wraps strategy-specific errors with action context."}],"identifier":{"url":"doc:\/\/Lockman\/documentation\/Lockman\/LockmanCancellationError","interfaceLanguage":"swift"},"topicSections":[{"generated":true,"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/Lockman\/documentation\/Lockman\/LockmanCancellationError\/init(action:boundaryId:reason:)"]},{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/Lockman\/documentation\/Lockman\/LockmanCancellationError\/action","doc:\/\/Lockman\/documentation\/Lockman\/LockmanCancellationError\/boundaryId","doc:\/\/Lockman\/documentation\/Lockman\/LockmanCancellationError\/reason"]},{"generated":true,"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/Lockman\/documentation\/Lockman\/LockmanCancellationError\/Error-Implementations","doc:\/\/Lockman\/documentation\/Lockman\/LockmanCancellationError\/LocalizedError-Implementations"]}],"kind":"symbol","relationshipsSections":[{"type":"conformsTo","kind":"relationships","title