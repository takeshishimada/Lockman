raph","inlineContent":[{"text":"一時的に制限を無効化したい場合に使用","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"デバッグやテスト時の動作確認に適用","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"limited"}],"type":"strong"},{"text":" - 数値制限","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["LockmanConcurrencyLimitedInfo(","    actionId: \"download\",","    concurrencyId: \"downloads\", ","    limit: .limited(3)",")"]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"指定した数まで同時実行を許可"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"制限を超える処理は拒否される"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"リソース保護とパフォーマンス最適化"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","level":3,"anchor":"%E5%90%8C%E6%99%82%E5%AE%9F%E8%A1%8C%E3%82%B0%E3%83%AB%E3%83%BC%E3%83%97","text":"同時実行グループ"},{"type":"paragraph","inlineContent":[{"type":"text","text":"同じ"},{"code":"concurrencyId","type":"codeVoice"},{"type":"text","text":"を持つ処理が同一グループとして管理され、グループ単位で同時実行数が制限されます。"}]},{"type":"codeListing","code":["\/\/ 同じグループ「downloads」として管理","LockmanConcurrencyLimitedInfo(","    actionId: \"downloadImage\",","    concurrencyId: \"downloads\",","    limit: .limited(3)",")","","LockmanConcurrencyLimitedInfo(","    actionId: \"downloadVideo\", ","    concurrencyId: \"downloads\",","    limit: .limited(3)",")"],"syntax":"swift"},{"type":"heading","level":2,"anchor":"%E4%BD%BF%E7%94%A8%E6%96%B9%E6%B3%95","text":"使用方法"},{"type":"heading","level":3,"anchor":"%E5%9F%BA%E6%9C%AC%E7%9A%84%E3%81%AA%E4%BD%BF%E7%94%A8%E4%BE%8B","text":"基本的な使用例"},{"type":"codeListing","code":["@LockmanConcurrencyLimited","enum ViewAction {","    case downloadFile(URL)","    case uploadFile(URL)","    case processImage(UIImage)","    ","    var lockmanInfo: LockmanConcurrencyLimitedInfo {","        switch self {","        case .downloadFile:","            return