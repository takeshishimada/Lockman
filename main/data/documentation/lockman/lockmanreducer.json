]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Lock-First Behavior","anchor":"Lock-First-Behavior"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"This reducer implements true lock-first behavior"}]},{"type":"text","text":": Lock acquisition feasibility is checked"},{"type":"text","text":" "},{"type":"text","text":"BEFORE the base reducer executes, preventing state mutations when locks cannot be acquired."},{"type":"text","text":" "},{"type":"text","text":"This ensures complete exclusive control over both state changes and effects."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Lock Execution Flow & UniqueId Consistency","anchor":"Lock-Execution-Flow--UniqueId-Consistency"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"LockmanInfo Capture"}],"type":"strong"},{"text":": Capture action’s lockmanInfo once to ensure consistent uniqueId","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Lock Feasibility Check"}]},{"type":"text","text":": Determine if lock can be acquired using strategy’s "},{"type":"codeVoice","code":"canLock"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Conditional State Mutation","type":"text"}],"type":"strong"},{"text":": Base reducer executes ONLY if lock acquisition succeeded","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Effect Execution"}],"type":"strong"},{"type":"text","text":": Run effects with the already-acquired lock using same lockmanInfo"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Guaranteed Unlock"}]},{"text":": Release lock when effects complete using matching uniqueId","type":"text"}]}]}]},{"level":2,"type":"heading","text":"When Lock Fails","anchor":"When-Lock-Fails"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"No state mutations occur (true lock-first behavior)","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Base reducer is never called","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Lock failure handler is invoked if provided"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Effect returns ","type":"text"},{"code":".none","type":"codeVoice"},{"text":" (operation is completely cancelled)","type":"text"}]}]}]},{"level":2,"type":"heading","text":"Strategy Resolution","anchor":"Strategy-Resolution"},{"inlineContent":[{"type":"text","text":"The reducer uses Effect-based strategy resolution to work around Swift’s existential type"},{"type":"text","text":" "},{"type":"text","text":"limitations, allowing type-safe strategy resolution before reducer execution."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Example","anchor":"Example"},{"syntax":"swift","code":["@Reducer","struct Feature {","  struct State: Equatable {","    var counter = 0  \/\/ ✅ Only mutated when lock can be acquired","  }","","  enum Action: LockmanSingleExecutionAction {","    case increment","    case decrement","","    var lockmanInfo: LockmanSingleExecutionInfo {","      switch self {","      case .increment, .decrement:","        return LockmanSingleExecutionInfo(actionId: \"counter\", mode: .boundary)","      }","    }","  }","","  var body: some ReducerOf<Self> {","    Reduce { state, action in","      switch action {","      case .increment:","        state.counter += 1  \/\/ ✅ Executes ONLY after lock feasibility check","        return .run { send in","          \/\/ This effect executes with the acquired lock","          await performSideEffect()","        }","      case .decrement:","        state.counter -= 1  \/\/ ✅ Executes ONLY after lock feasibility check","        return .none","      }","    }"