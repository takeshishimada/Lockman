ifferent "},{"type":"codeVoice","code":"uniqueId"},{"type":"text","text":" values"},{"type":"text","text":" "},{"type":"text","text":"remain unaffected."}]},{"type":"heading","anchor":"Rationale-for-uniqueId-based-Removal","level":2,"text":"Rationale for uniqueId-based Removal"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Using "},{"type":"codeVoice","code":"uniqueId"},{"type":"text","text":" instead of "},{"type":"codeVoice","code":"actionId"},{"type":"text","text":" for removal provides:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Precision","type":"text"}],"type":"strong"},{"text":": Only removes the specific lock instance that was acquired","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Safety","type":"text"}]},{"type":"text","text":": Prevents accidental removal of other locks with the same actionId"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Consistency"}]},{"type":"text","text":": Maintains 1:1 correspondence between lock() and unlock() calls"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Flexibility","type":"text"}],"type":"strong"},{"text":": Allows multiple lock instances with the same actionId in different scenarios","type":"text"}]}]}]},{"type":"heading","anchor":"Example","level":2,"text":"Example"},{"syntax":"swift","type":"codeListing","code":["let info1 = LockmanSingleExecutionInfo(actionId: \"sync\")","let info2 = LockmanSingleExecutionInfo(actionId: \"sync\")  \/\/ Same actionId, different uniqueId","","\/\/ Hypothetical scenario where both could be locked on different boundaries","strategy.lock(boundaryId: boundary1, info: info1)","strategy.lock(boundaryId: boundary2, info: info2)","","\/\/ Unlock only removes the specific instance","strategy.unlock(boundaryId: boundary1, info: info1)  \/\/ Only removes info1","\/\/ info2 remains locked on boundary2"]}]}],"references":{"doc://Lockman/documentation/Lockman/LockmanSingleExecutionInfo":{"identifier":"doc:\/\/Lockman\/documentation\/Lockman\/LockmanSingleExecutionInfo","abstract":[{"text":"Information required for single-execution locking behavior.","type":"text"}],"title":"LockmanSingleExecutionInfo","role":"symbol","navigatorTitle":[{"text":"LockmanSingleExecutionInfo","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LockmanSingleExecutionInfo","kind":"identifier"}],"type":"topic","url":"\/documentation\/lockman\/lockmansingleexecutioninfo","kind":"symbol"},"doc://Lockman/documentation/Lockman/LockmanSingleExecutionStrategy":{"kind":"symbol","title":"LockmanSingleExecutionStrategy","role":"symbol","identifier":"doc:\/\/Lockman\/documentation\/Lockman\/LockmanSingleExecutionStrategy","url":"\/documentation\/lockman\/lockmansingleexecutionstrategy","type":"topic","abstract":[{"type":"text","text":"A locking strategy that provides flexible execution control within a boundary."}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LockmanSingleExecutionStrategy","kind":"identifier"}],"navigatorTitle":[{"text":"LockmanSingleExecutionStrategy","kind":"identifier"}]},"doc://Lockman/documentation/Lockman":{"identifier":"doc:\/\/Lockman\/documentation\/Lockman","kind":"symbol","type":"topic","role":"collection","url":"\/documentation\/lockman","abstract":[{"text":"Elegant exclusive control for user actions in The Composable Architecture applications.","type":"text"}],"title":"Lockman"},"doc://Lockman/documentation/Lockman/LockmanSingleExecutionStrategy/unlock(boundaryId:info:)":{"role":"symbol","kind":"symbol","url":"\/documentation\/lockman\/lockmansingleexecutionstrategy\/unlock(boundaryid:info:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"unlock"},{"kind":"text","text":"<"},