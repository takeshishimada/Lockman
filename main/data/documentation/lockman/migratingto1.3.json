{"hierarchy":{"paths":[["doc:\/\/Lockman\/documentation\/Lockman"]]},"abstract":[{"text":"Update your code from Lockman 1.2 to take advantage of Lockman 1.3’s simplified API and enhanced safety features.","type":"text"}],"variants":[{"paths":["\/documentation\/lockman\/migratingto1.3"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/Lockman\/documentation\/Lockman\/MigratingTo1.3","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"kind":"article","metadata":{"title":"Migrating to 1.3","roleHeading":"Article","modules":[{"name":"Lockman"}],"role":"article"},"primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Lockman 1.3 introduces a major API simplification by removing the "},{"type":"codeVoice","code":"withLock"},{"type":"text","text":" methods in favor of the more consistent "},{"type":"codeVoice","code":"Effect.lock"},{"type":"text","text":" method chain approach. This change eliminates API duplication and provides a cleaner, more maintainable codebase."}]},{"type":"paragraph","inlineContent":[{"text":"The key improvements include:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Removal of ","type":"text"},{"code":"withLock","type":"codeVoice"},{"text":" methods for API consistency","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Enhanced safety through automatic lock management","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Simplified learning curve with fewer API options"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Better integration with TCA’s Effect patterns"}]}]}],"type":"unorderedList"},{"type":"heading","anchor":"Updating-dependencies","text":"Updating dependencies","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"To upgrade to Lockman 1.3, update your "},{"type":"codeVoice","code":"Package.swift"},{"type":"text","text":" file:"}]},{"type":"codeListing","code":["dependencies: [","  .package(","    url: \"https:\/\/github.com\/takeshishimada\/Lockman\",","    from: \"1.3.0\"","  )","]"],"syntax":"swift"},{"type":"heading","anchor":"Breaking-changes","text":"Breaking changes","level":2},{"type":"heading","anchor":"Removal-of-withLock-methods","text":"Removal of withLock methods","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"All "},{"type":"codeVoice","code":"withLock"},{"type":"text","text":" methods have been removed. Use "},{"type":"codeVoice","code":"Effect.lock"},{"type":"text","text":" method chain or "},{"type":"codeVoice","code":"Reducer.lock"},{"type":"text","text":" instead."}]},{"type":"paragraph","inlineContent":[{"text":"🚫 Before (1.2):","type":"text"}]},{"type":"codeListing","code":["return .withLock(","  operation: { send in","    try await performWork()","    await send(.completed)","  },","  catch handler: { error, send in","    await send(.failed(error))","  },","  lockFailure: { error, send in","    await send(.lockFailed)","  },","  action: action,","  boundaryId: CancelID.operation",")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"✅ After (1.3):"}]},{"type":"codeListing","code":["return .run { send in","  try await performWork()","  await send(.completed)","} catch: { error, send in","  await send(.failed(error))","}",".lock(","  action: action,","  boundaryId: CancelID.operation,","  lockFailure: { error, send in","    await send(.lockFailed)","  }",")"],"syntax":"swift"},{"type":"heading","anchor":"Removal-of-withLockconcatenating","text":"Removal of withLock(concatenating:)","level":3},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"withLock(concatenating:)"},{"text":" method has been renamed to ","type":"text"},{"type":"codeVoice","code":"Effect.lock(concatenating:)"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"🚫 Before (1.2):","type":"text"}]},{"type":"codeListing","code":["return .withLock(","  concatenating: [","    .run { send in await step1() },","    .run { send in await step2() },","    .run { send in await step3() }","  ],","  action: action,","  boundaryId: CancelID.workflow",")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"✅ After (1.3):"}]},{"type":"codeListing","code":["return .lock(","  concatenating: [","    .run { send in await step1() },","    .run { send in await step2() },","    .run { send in await step3() }","  ],","  action: action,","  boundaryId: CancelID.workflow",")"],"syntax":"swift"},{"type":"heading","anchor":"Manual-unlock-functionality-removed","text":"Manual unlock functionality removed","level":3},{"type":"paragraph","inlineContent":[{"text":"Manual unlock functionality (unlock parameter in operation) has been removed. All locks are now automatically managed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"🚫 Before (1.2):","type":"text"}]},{"type":"codeListing","code":["return .withLock(","  operation: { send, unlock in","    defer { unlock() }","    try await performWork()","    await send(.completed)","  },","  action: action,","  boundaryId: CancelID.operation",")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"✅ After (1.3):"}]},{"type":"codeListing","code":["return .run { send in","  try await performWork()","  await send(.completed)","}",".lock(","  action: action,","  boundaryId: CancelID.operation,","  unlockOption: .immediate \/\/ Control timing instead",")"],"syntax":"swift"},{"type":"heading","anchor":"Migration-strategy","text":"Migration strategy","level":2},{"type":"heading","anchor":"Step-1-Replace-withLock-with-Effectlock","text":"Step 1: Replace withLock with Effect.lock","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"For each "},{"type":"codeVoice","code":"withLock"},{"type":"text","text":" call:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Move the operation closure to a "},{"code":".run { }","type":"codeVoice"},{"type":"text","text":" effect"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Move the catch handler to ","type":"text"},{"type":"codeVoice","code":".catch { }"},{"text":" if present","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Chain "},{"code":".lock()","type":"codeVoice"},{"type":"text","text":" with the action and boundary parameters"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Move lockFailure to the lock method"}]}]}],"type":"orderedList"},{"type":"heading","anchor":"Step-2-Replace-withLockconcatenating-calls","text":"Step 2: Replace withLock(concatenating:) calls","level":3},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Change method name from "},{"type":"codeVoice","code":".withLock(concatenating:"},{"type":"text","text":" to "},{"type":"codeVoice","code":".lock(concatenating:"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Parameters remain the same"}],"type":"paragraph"}]}],"type":"orderedList"},{"type":"heading","anchor":"Step-3-Remove-manual-unlock-usage","text":"Step 3: Remove manual unlock usage","level":3},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Remove "},{"type":"codeVoice","code":"unlock"},{"type":"text","text":" parameter from operation closures"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Remove manual "},{"code":"unlock()","type":"codeVoice"},{"type":"text","text":" calls"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"unlockOption"},{"text":" parameter to control timing if needed","type":"text"}]}]}],"type":"orderedList"},{"type":"heading","anch