d in await processStep1() },","      .run { send in await processStep2() },","      .send(.workflowCompleted)","    ],","    unlockOption: .transition,","    action: action,","    boundaryId: CancelID.workflow","  )"],"syntax":"swift"},{"type":"heading","anchor":"Complex-manual-unlock-migration","text":"Complex manual unlock migration","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"🚫 Before (1.2):"}]},{"type":"codeListing","code":["case .complexOperation:","  return .withLock(","    operation: { send, unlock in","      try await phase1()","      ","      if shouldSkipPhase2 {","        unlock()","        await send(.skipped)","        return","      }","      ","      try await phase2()","      unlock()","      await send(.completed)","    },","    catch handler: { error, send, unlock in","      unlock()","      await send(.failed(error))","    },","    action: action,","    boundaryId: CancelID.complex","  )"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"✅ After (1.3):","type":"text"}]},{"type":"codeListing","code":["case .complexOperation:","  return .run { send in","    try await phase1()","    ","    if shouldSkipPhase2 {","      await send(.skipped)","      return","    }","    ","    try await phase2()","    await send(.completed)","  } catch: { error, send in","    await send(.failed(error))","  }","  .lock(","    action: action,","    boundaryId: CancelID.complex,","    unlockOption: .immediate \/\/ Automatic timing control","  )"],"syntax":"swift"},{"type":"heading","anchor":"Benefits-of-upgrading","text":"Benefits of upgrading","level":2},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Simplified API"}]},{"type":"text","text":": Single consistent method chain approach"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Enhanced safety"}]},{"text":": Automatic lock management prevents lock leaks","type":"tex