ndaries in Lockman.","type":"text"}],"identifier":"doc:\/\/Lockman\/documentation\/Lockman\/BoundaryOverview","role":"article","url":"\/documentation\/lockman\/boundaryoverview","title":"Boundary"},"doc://Lockman/documentation/Lockman/ChoosingStrategy":{"identifier":"doc:\/\/Lockman\/documentation\/Lockman\/ChoosingStrategy","url":"\/documentation\/lockman\/choosingstrategy","abstract":[{"text":"Learn how to select the right strategy for your use case.","type":"text"}],"type":"topic","role":"article","kind":"article","title":"Choosing a Strategy"},"doc://Lockman/documentation/Lockman/DebuggingGuide":{"kind":"article","url":"\/documentation\/lockman\/debuggingguide","identifier":"doc:\/\/Lockman\/documentation\/Lockman\/DebuggingGuide","abstract":[{"type":"text","text":"Learn how to debug Lockman-related issues in your application."}],"type":"topic","title":"Debugging Guide","role":"article"},"doc://Lockman/documentation/Lockman":{"kind":"symbol","role":"collection","type":"topic","abstract":[{"type":"text","text":"A library to implement exclusive control of user actions in application development using TCA."}],"url":"\/documentation\/lockman","identifier":"doc:\/\/Lockman\/documentation\/Lockman","title":"Lockman"}}}